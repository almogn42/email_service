# Email & SMS Service Configuration Example
# ---------------------------------------------------------
# Replace these placeholder values with your actual configuration.
# Do NOT commit your actual .env file to version control.

# ── General Service Settings ───────────────────────────────────
# Display name used in /status and root endpoints
SERVICE_NAME="Email Service Example"
# Enable highly verbose debug logging when True
DEBUG=False

# ── SMTP (Email) Settings ──────────────────────────────────────
# SMTP server hostname (e.g., smtp.gmail.com, smtp.office365.com)
SMTP_SERVER=smtp.example.com
# Port for SMTP (587 for STARTTLS, 465 for implicit SSL, 25 for plain text)
SMTP_PORT=587
# TLS mode: "starttls", "implicit", "none", or "auto"
SMTP_TLS_MODE=auto
# Login username for the SMTP server (usually the email address)
SMTP_USERNAME=your-username@example.com
# Login password (use app-specific passwords for services like Gmail)
SMTP_PASSWORD="your-secure-app-password"
# The "From" address that recipients will see
SMTP_FROM_EMAIL=no-reply@example.com

# ── Custom SSL CA / Verification Settings ───────────────
# Set to False to disable SSL certificate verification (useful for self-signed certs)
SMTP_SSL_VERIFY=True
# Optional: Path to a custom CA certificate file (e.g. /path/to/org_ca.pem)
SMTP_CA_CERT_PATH=

# ── SMS Gateway Settings ───────────────────────────────────────
# External SMS API endpoint
SMS_API_URL=https://api.example-sms-gateway.com/send
# OAuth client ID for the SMS gateway
SMS_CLIENT_ID=your-sms-client-id
# OAuth client secret for the SMS gateway
SMS_CLIENT_SECRET=your-sms-client-secret
# OAuth scope for the SMS gateway
SMS_SCOPE=sms.send
# Application ID sent in SMS payload
SMS_APP_ID=your-app-id
# Sender name shown to SMS recipients
SMS_SENDER_NAME=MyCompanyApp

# Template for the SMS JSON payload formatting.
# Available placeholders: {app_id}, {sender_name}, {text}, {recipient}, {recipient_type}
SMS_PAYLOAD_TEMPLATE='{"applicationId": "{app_id}", "smsSenderName": "{sender_name}", "smsMessageText": "{text}", "recipient": "{recipient}", "recipientType": {recipient_type}}'

# ── Basic Authentication ───────────────────────────────────────
# Dictionary mapping username to password. Use plain-text passwords here, 
# and the application will automatically hash them on first startup.
BASIC_AUTH_USERS={"admin": "change-this-password", "user1": "another-password"}

# ── API / Bearer Tokens ────────────────────────────────────────
# List of valid tokens accepted by the Bearer authentication endpoints
API_TOKENS=["your-secure-api-token-1", "your-secure-api-token-2"]
