# Email Service Configuration

# Security settings
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# SMTP Configuration (Gmail example)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com

# SMS settings
SMS_API_URL=http://localhost:8080/sms-api
SMS_CLIENT_ID= 
SMS_CLIENT_SECRET=
SMS_SCOPE=
SMS_APP_ID=
SMS_SENDER_NAME=
SMS_PAYLOAD_TEMPLATE='{"applicationId": "{app_id}", "smsSenderName": "{sender_name}", "smsMessageText": "{text}", "recipient": "{recipient}", "recipientType": {recipient_type}}'

# Service settings
SERVICE_NAME=Email Service
DEBUG=False

# Basic Auth Users (format: username=password)
# In production, store hashed passwords in a database
BASIC_AUTH_USERS={"admin": "changeme", "user1": "password123"}

# API Tokens for Bearer/OAuth authentication
API_TOKENS=["your-api-token-here", "another-secure-token"]
